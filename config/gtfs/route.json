{
    "default_route_id_enabled": true,
    "use_route_short_name_for_route_id": true,
    "route_short_name_to_route_id_configs": [
        {
            "route_short_name": "SJP",
            "route_id": 8
        },
        {
            "route_short_name": "SJS",
            "route_id": 9
        }
    ],
    "route_short_name_cleaners": [
        {
            "regex": "(^route )",
            "ignore_case": true
        },
        {
            "regex": "^0+",
            "ignore_case": true
        }
    ],
    "route_colors_ignored": [
        "000000"
    ],
    "route_colors": [
        {
            "route_short_name": "1",
            "color": "93673D"
        },
        {
            "route_short_name": "2",
            "color": "945786"
        },
        {
            "route_short_name": "3",
            "color": "6AADDE"
        },
        {
            "route_short_name": "4",
            "color": "823748"
        },
        {
            "route_short_name": "5",
            "color": "418B73"
        },
        {
            "route_short_name": "6",
            "color": "D5B141"
        },
        {
            "route_short_name": "7",
            "color": "DB543C"
        },
        {
            "route_short_name": "8",
            "color": "B4C04C"
        },
        {
            "route_short_name": "9",
            "color": "586A4A"
        }
    ],
    "default_route_long_name_enabled": true,
    "direction_splitter_enabled": false,
    "direction_splitter_enabled_comment": "not useful because all loops",
    "direction_finder_enabled": true,
    "trip_headsign_cleaners": [
        {
            "regex": "( \\(.+\\)$)",
            "ignore_case": true
        }
    ],
    "stop_name_cleaners": [
        {
            "regex": "(^([^-]+)-([^-]+)$)",
            "ignore_case": true,
            "replacement": "$2 - $3"
        }
    ]
}